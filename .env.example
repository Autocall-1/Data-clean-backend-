# ─── MongoDB ─────────────────────────────────────────────
MONGODB_URL=mongodb+srv://user:pass@cluster0.xxx.mongodb.net/dataclean?retryWrites=true&w=majority
MONGODB_DB_NAME=dataclean

# ─── Firebase Admin SDK ───────────────────────────────────
# Render pe: Environment → Add Secret File → /etc/secrets/firebase.json
# Ya JSON string as env var:
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─── Razorpay Subscription ────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=your_secret_here

# Razorpay Dashboard → Plans → Create Plan → Copy ID
# Period: monthly | Interval: 1 | Amount: 49900 paise (₹499)
RAZORPAY_PLAN_ID=plan_XXXXXXXXXXXXXXXXX

# Razorpay Dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ─── AI Provider ─────────────────────────────────────────
AI_PROVIDER=claude      # claude | openai | gemini
CLAUDE_API_KEY=sk-ant-api03-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...

# ─── Cloudinary (optional, Pro users ke liye) ────────────
CLOUDINARY_API_KEY=your_key
CLOUDINARY_API_SECRET=your_secret

# ─── CORS ────────────────────────────────────────────────
ALLOWED_ORIGINS=https://YOUR_USERNAME.github.io
